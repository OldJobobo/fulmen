#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
roles=(planner critic explorer worker verifier assembler)
failures=0

fail() {
  printf 'validate: %s\n' "$*" >&2
  failures=$((failures + 1))
}

require_file() {
  [[ -f "$1" ]] || fail "missing file: $1"
}

require_contains() {
  local file="$1"
  local pattern="$2"
  if ! grep -Eq "$pattern" "$file"; then
    fail "missing pattern in $file: $pattern"
  fi
}

reject_contains() {
  local file="$1"
  local pattern="$2"
  if grep -Eq "$pattern" "$file"; then
    fail "unexpected pattern in $file: $pattern"
  fi
}

reject_unquoted_frontmatter_colons() {
  local file="$1"
  if awk '
    BEGIN { in_fm = 0; line = 0 }
    /^---$/ { in_fm = !in_fm; next }
    in_fm {
      line++
      if ($0 ~ /^[A-Za-z_][A-Za-z0-9_-]*: [^"'\''[{].*: /) {
        printf "%s:%d:%s\n", FILENAME, FNR, $0
        found = 1
      }
    }
    END { exit found ? 0 : 1 }
  ' "$file"; then
    fail "unquoted YAML frontmatter value contains ': ': $file"
  fi
}

codex_skill="$ROOT_DIR/implementations/codex/skills/fulmen/SKILL.md"
claude_skill="$ROOT_DIR/implementations/claude/skills/fulmen/SKILL.md"

require_file "$codex_skill"
require_file "$claude_skill"
require_file "$ROOT_DIR/implementations/codex/skills/fulmen/agents/openai.yaml"
reject_unquoted_frontmatter_colons "$codex_skill"
reject_unquoted_frontmatter_colons "$claude_skill"
reject_contains "$ROOT_DIR/implementations/codex/skills/fulmen/agents/openai.yaml" 'allow_implicit_invocation: false'

for role in "${roles[@]}"; do
  require_file "$ROOT_DIR/implementations/codex/agents/$role.toml"
  require_file "$ROOT_DIR/implementations/claude/agents/$role.md"
  require_contains "$codex_skill" "\\b$role\\b"
  require_contains "$claude_skill" "\\b$role\\b"
done

for option in low standard high light full pathworking; do
  require_contains "$codex_skill" "\\-$option\\b"
  require_contains "$claude_skill" "\\-$option\\b"
done

for file in "$ROOT_DIR"/implementations/codex/agents/*.toml; do
  require_contains "$file" '^name = "'
  require_contains "$file" '^description = "'
  require_contains "$file" '^sandbox_mode = "(read-only|workspace-write|danger-full-access)"'
  require_contains "$file" '^developer_instructions = """'
done

for file in "$ROOT_DIR"/implementations/claude/agents/*.md; do
  require_contains "$file" '^---$'
  require_contains "$file" '^name: '
  require_contains "$file" '^description: '
  require_contains "$file" '^model: '
  require_contains "$file" 'disallowedTools:'
  reject_unquoted_frontmatter_colons "$file"
done

require_contains "$ROOT_DIR/implementations/codex/agents/verifier.toml" 'sandbox_mode = "read-only"'
require_contains "$ROOT_DIR/implementations/codex/agents/verifier.toml" 'Do not write or edit any files'
require_contains "$ROOT_DIR/implementations/claude/agents/verifier.md" 'disallowedTools: \["Edit", "Write", "Agent"\]'
require_contains "$ROOT_DIR/implementations/claude/agents/verifier.md" 'Do not write or edit any files'
require_contains "$codex_skill" 'multi_agent_v1\.close_agent'
require_contains "$codex_skill" 'Do not reuse completed agents across separate'
require_contains "$codex_skill" 'The parent session remains the source of truth'
require_contains "$claude_skill" 'The parent session remains the source of truth'
require_contains "$codex_skill" "Do not let a subagent's plan become the task"
require_contains "$claude_skill" "Do not let a subagent's plan become the task"
require_contains "$ROOT_DIR/implementations/codex/agents/planner.toml" "The Fulmen brief is authoritative"
require_contains "$ROOT_DIR/implementations/claude/agents/planner.md" "The Fulmen brief is authoritative"
require_contains "$ROOT_DIR/implementations/codex/agents/worker.toml" "Your scope-limited task is your full authority"
require_contains "$ROOT_DIR/implementations/claude/agents/worker.md" "Your scope-limited task is your full authority"
require_contains "$ROOT_DIR/implementations/codex/agents/verifier.toml" "Scope drift is a defect"
require_contains "$ROOT_DIR/implementations/claude/agents/verifier.md" "Scope drift is a defect"

if [[ "$failures" -gt 0 ]]; then
  printf 'validate failed: %s issue(s)\n' "$failures" >&2
  exit 1
fi

printf 'validate ok\n'
